generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  BILLING_ADMIN
}

enum PlanType {
  FREE
  CREATOR
  ENTERPRISE
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  PAUSED
}

enum BillingOwnerType {
  USER
  ENTERPRISE
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  passwordHash     String
  emailVerified    Boolean    @default(false)
  createdAt        DateTime   @default(now())

  adminRole        AdminRole?
  isSuspended      Boolean    @default(false)
  suspendedAt      DateTime?
  suspensionReason String?
  sessionVersion   Int        @default(1)

  // External HeyGen workspace member ID, for reconciling accounts with
  // HeyGen ahead of a future API integration. Not used for auth.
  heygenUserId     String?

  // Email a payment processor (Stripe) has on file for this person, when it
  // differs from their portal login email. Records a known correspondence
  // without asserting it as the account's identity.
  stripeEmail      String?

  userRoles               UserRole[]
  enterprises             Enterprise[]      @relation("EnterpriseOwner")
  enterpriseMembers       EnterpriseMember[]
  subscriptions           Subscription[]
  avatars                 Avatar[]
  bookings                Booking[]
  emailVerificationTokens EmailVerificationToken[]
  invitesSent             Invite[]          @relation("InvitedByUser")
  systemEvents            SystemEvent[]
  emailLogs               EmailLog[]
  adminLogs               AdminLog[]        @relation("AdminUser")
  adminLogsAsTarget       AdminLog[]        @relation("AdminLogTarget")
  bookingNotesAuthored    BookingNote[]

  @@map("users")
}

model Role {
  id                String             @id @default(cuid())
  name              String             @unique
  permissions       RolePermission[]
  userRoles         UserRole[]
  invites           Invite[]
  enterpriseMembers EnterpriseMember[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Enterprise {
  id          String   @id @default(cuid())
  name        String
  ownerUserId String
  status      String   @default("active")
  createdAt   DateTime @default(now())

  // Raw HeyGen workspace identifier (e.g. "YM502_Concinnity"), preserved
  // alongside the cleaned display name for a future HeyGen integration.
  heygenWorkspaceId String?

  owner         User               @relation("EnterpriseOwner", fields: [ownerUserId], references: [id])
  members       EnterpriseMember[]
  subscriptions Subscription[]
  avatars       Avatar[]
  bookings      Booking[]
  invites       Invite[]

  @@index([ownerUserId])
  @@map("enterprises")
}

model EnterpriseMember {
  id           String @id @default(cuid())
  enterpriseId String
  userId       String
  roleId       String

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id])

  @@unique([enterpriseId, userId])
  @@map("enterprise_members")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String?
  enterpriseId         String?

  ownerType            BillingOwnerType
  // Not unique: a single Stripe customer can legitimately hold more than one
  // concurrent subscription (e.g. a base plan plus a separate seats add-on).
  // stripeSubscriptionId is the real per-subscription identity.
  stripeCustomerId     String
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeProductId      String?

  planType             PlanType           @default(FREE)
  status               SubscriptionStatus @default(INCOMPLETE)

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enterprise           Enterprise?        @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  payments             Payment[]

  @@index([userId])
  @@index([enterpriseId])
  @@index([ownerType])
  @@index([status])
  @@index([planType])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum PaymentType {
  booking
  subscription
  other
}

model Payment {
  id                    String         @id @default(cuid())
  type      PaymentType       
  stripeInvoiceId       String?        @unique
  stripePaymentIntentId String?        @unique
  amount                Int
  currency              String         @default("aud")

  status                PaymentStatus  @default(unpaid)

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Links to business objects (optional, depending on type)
  bookingId      String?
  subscriptionId String?

  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([subscriptionId])
  @@map("payments")
}

model Avatar {
  id             String   @id @default(cuid())
  userId         String
  enterpriseId   String?
  heygenAvatarId String?
  name           String
  status         String   @default("pending")
  previewUrl     String?
  videoUrl       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  enterprise Enterprise? @relation(fields: [enterpriseId], references: [id])

  @@index([userId])
  @@index([enterpriseId])
  @@map("avatars")
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum CaptureLocationType {
  capital_city
  regional_other
  multi_location
}

enum AustralianCapitalCity {
  sydney
  melbourne
  brisbane
  perth
  adelaide
  hobart
  canberra
  darwin
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  enterpriseId  String?
  requestedDate DateTime
  timeStart     String
  timeEnd       String
  capturesCount        Int                  @default(1)
  status               BookingStatus        @default(pending)
  paymentStatus        PaymentStatus        @default(unpaid)
  notes                String?
  captureLocationType  CaptureLocationType?
  capitalCity          AustralianCapitalCity?
  suburbOrTown         String?
  stateOrTerritory     String?
  postcode             String?
  addressLine1         String?
  addressLine2         String?
  locationNotes        String?
  createdAt            DateTime             @default(now())

  user         User        @relation(fields: [userId], references: [id])
  enterprise   Enterprise? @relation(fields: [enterpriseId], references: [id])
  payments     Payment[]
  participants BookingCaptureParticipant[]
  adminNotes   BookingNote[]

  @@index([userId])
  @@index([enterpriseId])
  @@map("bookings")
}

// Internal, admin-only annotations on a booking — distinct from Booking.notes
// (customer-facing, set on the booking form). Append-only: notes are never
// edited or deleted, so this table doubles as its own history/audit trail.
model BookingNote {
  id          String   @id @default(cuid())
  bookingId   String
  adminUserId String
  note        String
  createdAt   DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  adminUser User    @relation(fields: [adminUserId], references: [id])

  @@index([bookingId])
  @@index([adminUserId])
  @@map("booking_notes")
}

model BookingCaptureParticipant {
  id            String   @id @default(cuid())
  bookingId     String
  sortOrder     Int
  firstName     String
  contactNumber String
  createdAt     DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, sortOrder])
  @@index([bookingId])
  @@map("booking_capture_participants")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model Invite {
  id           String   @id @default(cuid())
  enterpriseId String
  email        String
  roleId       String
  token        String   @unique
  status       String   @default("pending")
  invitedById  String?
  createdAt    DateTime @default(now())

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])
  invitedBy  User?      @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([enterpriseId])
  @@index([roleId])
  @@index([invitedById])
  @@map("invites")
}

model SystemEvent {
  id        String   @id @default(cuid())
  type      String
  source    String
  message   String
  metadata  Json?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("system_events")
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String?
  emailType String
  status    String
  provider  String
  response  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("email_logs")
}

model Webhook {
  id         String   @id @default(cuid())
  source     String
  eventType  String
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("webhooks")
}

model AdminLog {
  id           String   @id @default(cuid())
  adminUserId  String
  action       String
  entityType   String
  entityId     String?
  targetUserId String?
  reason       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  adminUser  User  @relation("AdminUser", fields: [adminUserId], references: [id])
  targetUser User? @relation("AdminLogTarget", fields: [targetUserId], references: [id])

  @@index([adminUserId])
  @@index([targetUserId])
  @@map("admin_logs")
}